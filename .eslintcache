r\\PhpstormProjects\\styled-components\\src\\App.js",[],"C:\\Users\\Vladimir\\PhpstormProjects\\styled-components\\src\\components\\Button.js",["32"],"C:\\Users\\Vladimir\\PhpstormProjects\\styled-components\\src\\components\\Console.js",["33"],"import React, {useState} from 'react'\r\nimport styled from 'styled-components'\r\nimport Flex from \"./Flex\"\r\nimport Line from \"./Line\";\r\n\r\nconst StyledConsole = styled.textarea`\r\n  width: 100%;\r\n  height: 70vh;\r\n  background: black;\r\n  color: ${props => props.color || props.theme.colors.primary};\r\n  font-size: 1.5rem;\r\n  border: none;\r\n  resize: none;\r\n\r\n  &:focus {\r\n    outline: none;\r\n  }\r\n  @media ${props => props.theme.media.phone} {\r\n    border: 1px solid red;\r\n  }  \r\n  @media ${props => props.theme.media.tablet} {\r\n    border: 1px solid green;\r\n  }\r\n`\r\n\r\n\r\nconst Console = ({color, ...props}) => {\r\n    const [lines, setLines] = useState(['C/Users/Documents'])\r\n    const onKeyPress = e => {\r\n        if (e.charCode == 13) {\r\n            setLines([...lines, 'C/Users/Documents'])\r\n        }\r\n    }\r\n    return (\r\n        <Flex>\r\n            <Flex direction={'column'} margin='0 10px'>\r\n                {lines.map(line =>\r\n                    <Line color={color}>{line}</Line>)}\r\n            </Flex>\r\n            <StyledConsole onKeyPress={onKeyPress} color={color} {...props}/>\r\n        </Flex>\r\n    )\r\n}\r\n\r\nexport default Console;",["34","35"],"C:\\Users\\Vladimir\\PhpstormProjects\\styled-components\\src\\components\\Line.js",[],"C:\\Users\\Vladimir\\PhpstormProjects\\styled-components\\src\\index.js",["36"],"C:\\Users\\Vladimir\\PhpstormProjects\\styled-components\\src\\components\\Title.js",[],"C:\\Users\\Vladimir\\PhpstormProjects\\styled-components\\src\\components\\Flex.js",[],{"ruleId":"37","severity":1,"message":"38","line":43,"column":7,"nodeType":"39","messageId":"40","endLine":43,"endColumn":18},{"ruleId":"41","severity":1,"message